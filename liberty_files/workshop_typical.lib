/* =============================================================================
 * File:    workshop_typical.lib
 * Author:  OpenSTA Workshop
 * Description:
 *   A simplified Liberty (.lib) technology library for the OpenSTA workshop.
 *   This models a fictional "workshop_45nm" process at typical conditions.
 *
 *   This library contains the basic cells needed for the Wallace Tree
 *   Multiplier designs:
 *     - BUF    (buffer)
 *     - INV    (inverter)
 *     - AND2   (2-input AND)
 *     - OR2    (2-input OR)
 *     - XOR2   (2-input XOR)
 *     - MUX2   (2-input multiplexer)
 *     - DFFR   (D flip-flop with active-low reset)
 *
 *   Timing values are representative but simplified for educational use.
 *   Real libraries have lookup tables indexed by input slew and output load.
 *   Here we use single scalar values for clarity.
 *
 *   Units:
 *     Time:         ns
 *     Capacitance:  pF
 *     Voltage:      V
 *     Current:      mA
 *     Resistance:   kOhm
 * ============================================================================= */

library (workshop_typical) {

    /* ---- Library-Level Attributes ---- */
    technology (cmos);
    delay_model : table_lookup;

    /* Units */
    time_unit           : "1ns";
    voltage_unit        : "1V";
    current_unit        : "1mA";
    capacitive_load_unit (1, pf);
    pulling_resistance_unit : "1kohm";
    leakage_power_unit  : "1nW";

    /* Operating Conditions */
    nom_process : 1.0;
    nom_voltage : 1.1;
    nom_temperature : 25.0;

    /* Default values */
    default_input_pin_cap       : 0.01;
    default_output_pin_cap      : 0.0;
    default_max_transition      : 1.0;
    default_fanout_load         : 1.0;
    default_cell_leakage_power  : 0.0;

    /* Input/Output voltage thresholds */
    input_threshold_pct_rise  : 50;
    input_threshold_pct_fall  : 50;
    output_threshold_pct_rise : 50;
    output_threshold_pct_fall : 50;
    slew_lower_threshold_pct_rise : 20;
    slew_lower_threshold_pct_fall : 20;
    slew_upper_threshold_pct_rise : 80;
    slew_upper_threshold_pct_fall : 80;

    /* =====================================================================
     * LOOKUP TABLE TEMPLATES
     * These define the axes for delay/transition lookup tables.
     * index_1 = input transition time (slew)
     * index_2 = total output net capacitance (load)
     * ===================================================================== */
    lu_table_template (delay_template_2x2) {
        variable_1 : input_net_transition;
        variable_2 : total_output_net_capacitance;
        index_1 ("0.05, 0.4");
        index_2 ("0.01, 0.1");
    }

    /* =====================================================================
     * CELL: BUF (Buffer)
     * Function: Y = A
     * ===================================================================== */
    cell (BUF) {
        area : 1.0;
        pin (A) {
            direction : input;
            capacitance : 0.01;
        }
        pin (Y) {
            direction : output;
            function : "A";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.04, 0.10", \
                            "0.08, 0.15");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.03, 0.09", \
                            "0.07, 0.13");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.08, 0.16");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.04, 0.11", \
                            "0.07, 0.14");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: INV (Inverter)
     * Function: Y = !A
     * ===================================================================== */
    cell (INV) {
        area : 0.8;
        pin (A) {
            direction : input;
            capacitance : 0.008;
        }
        pin (Y) {
            direction : output;
            function : "!A";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : negative_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.03, 0.08", \
                            "0.06, 0.12");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.02, 0.07", \
                            "0.05, 0.11");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.04, 0.10", \
                            "0.06, 0.14");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.03, 0.09", \
                            "0.05, 0.12");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: AND2 (2-input AND gate)
     * Function: Y = A & B
     * ===================================================================== */
    cell (AND2) {
        area : 1.5;
        pin (A) {
            direction : input;
            capacitance : 0.01;
        }
        pin (B) {
            direction : input;
            capacitance : 0.01;
        }
        pin (Y) {
            direction : output;
            function : "A B";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.10, 0.20");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.09, 0.18");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.08, 0.16");
                }
            }
            timing () {
                related_pin : "B";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.10, 0.20");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.09, 0.18");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.08, 0.16");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: OR2 (2-input OR gate)
     * Function: Y = A | B
     * ===================================================================== */
    cell (OR2) {
        area : 1.5;
        pin (A) {
            direction : input;
            capacitance : 0.01;
        }
        pin (B) {
            direction : input;
            capacitance : 0.01;
        }
        pin (Y) {
            direction : output;
            function : "A+B";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.05, 0.13", \
                            "0.09, 0.19");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.04, 0.11", \
                            "0.08, 0.17");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.08, 0.16");
                }
            }
            timing () {
                related_pin : "B";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.05, 0.13", \
                            "0.09, 0.19");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.04, 0.11", \
                            "0.08, 0.17");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.05, 0.12", \
                            "0.08, 0.16");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: XOR2 (2-input XOR gate)
     * Function: Y = A ^ B
     * ===================================================================== */
    cell (XOR2) {
        area : 2.5;
        pin (A) {
            direction : input;
            capacitance : 0.012;
        }
        pin (B) {
            direction : input;
            capacitance : 0.012;
        }
        pin (Y) {
            direction : output;
            function : "A^B";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : non_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.13, 0.25");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.12, 0.23");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.12, 0.22");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.11, 0.20");
                }
            }
            timing () {
                related_pin : "B";
                timing_sense : non_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.13, 0.25");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.12, 0.23");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.12, 0.22");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.11, 0.20");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: MUX2 (2-input Multiplexer)
     * Function: Y = S ? B : A
     * ===================================================================== */
    cell (MUX2) {
        area : 3.0;
        pin (A) {
            direction : input;
            capacitance : 0.01;
        }
        pin (B) {
            direction : input;
            capacitance : 0.01;
        }
        pin (S) {
            direction : input;
            capacitance : 0.01;
        }
        pin (Y) {
            direction : output;
            function : "(A !S)+(B S)";
            max_capacitance : 0.5;
            timing () {
                related_pin : "A";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.12, 0.22");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.11, 0.20");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.10, 0.20");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
            }
            timing () {
                related_pin : "B";
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.12, 0.22");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.11, 0.20");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.10, 0.20");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.06, 0.14", \
                            "0.09, 0.18");
                }
            }
            timing () {
                related_pin : "S";
                timing_sense : non_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.09, 0.18", \
                            "0.14, 0.24");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.08, 0.16", \
                            "0.13, 0.22");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.08, 0.16", \
                            "0.11, 0.20");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.07, 0.14", \
                            "0.10, 0.18");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: DFFR (D Flip-Flop with Active-Low Async Reset)
     * Function: Q = D on rising edge of CLK, Q = 0 when RN = 0
     * ===================================================================== */
    cell (DFFR) {
        area : 6.0;
        ff (IQ, IQN) {
            clocked_on       : "CLK";
            next_state       : "D";
            clear            : "!RN";
            clear_preset_var1 : L;
        }
        pin (CLK) {
            direction : input;
            capacitance : 0.015;
            clock : true;
            min_pulse_width_low  : 0.2;
            min_pulse_width_high : 0.2;
        }
        pin (D) {
            direction : input;
            capacitance : 0.01;
            timing () {
                related_pin : "CLK";
                timing_type : setup_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.08, 0.10", \
                            "0.12, 0.15");
                }
                fall_constraint (delay_template_2x2) {
                    values ("0.08, 0.10", \
                            "0.12, 0.15");
                }
            }
            timing () {
                related_pin : "CLK";
                timing_type : hold_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.03, 0.04", \
                            "0.04, 0.05");
                }
                fall_constraint (delay_template_2x2) {
                    values ("0.03, 0.04", \
                            "0.04, 0.05");
                }
            }
        }
        pin (RN) {
            direction : input;
            capacitance : 0.01;
            timing () {
                related_pin : "CLK";
                timing_type : recovery_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.06, 0.08", \
                            "0.09, 0.12");
                }
            }
            timing () {
                related_pin : "CLK";
                timing_type : removal_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.03, 0.04", \
                            "0.04, 0.05");
                }
            }
        }
        pin (Q) {
            direction : output;
            function : "IQ";
            max_capacitance : 0.5;
            timing () {
                related_pin : "CLK";
                timing_type : rising_edge;
                timing_sense : non_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.10, 0.22", \
                            "0.15, 0.28");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.09, 0.20", \
                            "0.14, 0.26");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.12, 0.22");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.11, 0.20");
                }
            }
            timing () {
                related_pin : "RN";
                timing_type : clear;
                timing_sense : positive_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.12, 0.25", \
                            "0.18, 0.32");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.10, 0.22", \
                            "0.16, 0.28");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.10, 0.20", \
                            "0.14, 0.24");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.12, 0.22");
                }
            }
        }
    }

    /* =====================================================================
     * CELL: DFF (D Flip-Flop without Reset)
     * Function: Q = D on rising edge of CLK
     * ===================================================================== */
    cell (DFF) {
        area : 5.0;
        ff (IQ, IQN) {
            clocked_on : "CLK";
            next_state : "D";
        }
        pin (CLK) {
            direction : input;
            capacitance : 0.015;
            clock : true;
            min_pulse_width_low  : 0.2;
            min_pulse_width_high : 0.2;
        }
        pin (D) {
            direction : input;
            capacitance : 0.01;
            timing () {
                related_pin : "CLK";
                timing_type : setup_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.08, 0.10", \
                            "0.12, 0.15");
                }
                fall_constraint (delay_template_2x2) {
                    values ("0.08, 0.10", \
                            "0.12, 0.15");
                }
            }
            timing () {
                related_pin : "CLK";
                timing_type : hold_rising;
                rise_constraint (delay_template_2x2) {
                    values ("0.03, 0.04", \
                            "0.04, 0.05");
                }
                fall_constraint (delay_template_2x2) {
                    values ("0.03, 0.04", \
                            "0.04, 0.05");
                }
            }
        }
        pin (Q) {
            direction : output;
            function : "IQ";
            max_capacitance : 0.5;
            timing () {
                related_pin : "CLK";
                timing_type : rising_edge;
                timing_sense : non_unate;
                cell_rise (delay_template_2x2) {
                    values ("0.10, 0.22", \
                            "0.15, 0.28");
                }
                cell_fall (delay_template_2x2) {
                    values ("0.09, 0.20", \
                            "0.14, 0.26");
                }
                rise_transition (delay_template_2x2) {
                    values ("0.08, 0.18", \
                            "0.12, 0.22");
                }
                fall_transition (delay_template_2x2) {
                    values ("0.07, 0.16", \
                            "0.11, 0.20");
                }
            }
        }
    }

} /* end library */
